---
import BaseLayout from '../../layouts/BaseLayout.astro';
import hero from '../../content/whats-on-near-nice-and-antibes-hero.html?raw';
import main from '../../content/whats-on-main.html?raw';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: { '@id': `${Astro.site}#`, name: 'Vert Bocage' },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: {
        '@id': `${Astro.site}whats-on-near-nice-and-antibes/`,
        name: "What's on near Nice and Antibes",
      },
    },
  ],
});
---

<BaseLayout
  title="What's on near Nice and Antibes | Villa Vert Bocage"
  description="Ideas for days out and events near Nice, Antibes and Villa Vert Bocage in the South of France."
  canonicalPath="/whats-on-near-nice-and-antibes/"
  activeNav="whats-on"
  bodyClass="wp-singular page wp-theme-villazilla-85 sidebar-primary"
>
  <script slot="head" type="application/ld+json" set:html={breadcrumbLd} />
  <div slot="hero" set:html={hero} />
  <div set:html={main} />
</BaseLayout>
