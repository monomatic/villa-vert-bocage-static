---
import BaseLayout from '../../layouts/BaseLayout.astro';
import main from '../../content/news-events-main.html?raw';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: { '@id': `${Astro.site}#`, name: 'Vert Bocage' },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: { '@id': `${Astro.site}news-events/`, name: 'News & Events' },
    },
  ],
});
---

<BaseLayout
  title="News & Events | Villa Rental South of France – Vert Bocage"
  description="News and information from Villa Vert Bocage — renting a villa in the South of France."
  canonicalPath="/news-events/"
  activeNav="news-events"
  bodyClass="blog wp-theme-villazilla-85 sidebar-primary"
>
  <script slot="head" type="application/ld+json" set:html={breadcrumbLd} />
  <div set:html={main} />
</BaseLayout>
