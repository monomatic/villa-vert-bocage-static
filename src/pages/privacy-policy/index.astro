---
import BaseLayout from '../../layouts/BaseLayout.astro';
import main from '../../content/privacy-main.html?raw';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: { '@id': `${Astro.site}#`, name: 'Vert Bocage' },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: { '@id': `${Astro.site}privacy-policy/`, name: 'Privacy Policy' },
    },
  ],
});
---

<BaseLayout
  title="Privacy Policy | Villa Rental South of France – Vert Bocage"
  description="Privacy Policy for Villa Vert Bocage — how we handle your personal data."
  canonicalPath="/privacy-policy/"
  activeNav="privacy-policy"
  bodyClass="wp-singular page wp-theme-villazilla-85 privacy-policy sidebar-primary"
>
  <script slot="head" type="application/ld+json" set:html={breadcrumbLd} />
  <div set:html={main} />
</BaseLayout>
