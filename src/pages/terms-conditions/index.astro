---
import BaseLayout from '../../layouts/BaseLayout.astro';
import main from '../../content/terms-main.html?raw';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: { '@id': `${Astro.site}#`, name: 'Vert Bocage' },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: { '@id': `${Astro.site}terms-conditions/`, name: 'Terms & Conditions' },
    },
  ],
});
---

<BaseLayout
  title="Terms & Conditions | Villa Rental South of France – Vert Bocage"
  description="Terms and conditions for Villa Vert Bocage holiday villa rental."
  canonicalPath="/terms-conditions/"
  activeNav="terms-conditions"
  bodyClass="wp-singular page wp-theme-villazilla-85 terms-conditions sidebar-primary"
>
  <script slot="head" type="application/ld+json" set:html={breadcrumbLd} />
  <div set:html={main} />
</BaseLayout>
