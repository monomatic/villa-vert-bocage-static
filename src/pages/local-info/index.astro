---
import BaseLayout from '../../layouts/BaseLayout.astro';
import hero from '../../content/local-info-hero.html?raw';
import main from '../../content/local-info-main.html?raw';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: { '@id': `${Astro.site}#`, name: 'Vert Bocage' },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: { '@id': `${Astro.site}local-info/`, name: 'Local Area' },
    },
  ],
});
---

<BaseLayout
  title="Local Area | Villa Rental South of France – Vert Bocage"
  description="Local information for guests staying at Villa Vert Bocage in Le Rouret, South of France."
  canonicalPath="/local-info/"
  activeNav="local-info"
  bodyClass="wp-singular page wp-theme-villazilla-85 sidebar-primary"
>
  <script slot="head" type="application/ld+json" set:html={breadcrumbLd} />
  <div slot="hero" set:html={hero} />
  <div set:html={main} />
</BaseLayout>
