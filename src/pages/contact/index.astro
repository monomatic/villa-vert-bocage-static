---
import BaseLayout from '../../layouts/BaseLayout.astro';
import hero from '../../content/contact-hero.html?raw';
import '../../styles/contact-static.css';

const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: { '@id': `${Astro.site}#`, name: 'Vert Bocage' },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: { '@id': `${Astro.site}contact/`, name: 'Contact' },
    },
  ],
});
---

<BaseLayout
  title="Contact | Villa Rental South of France – Vert Bocage"
  description="Contact Villa Vert Bocage about holiday villa rental in Le Rouret, South of France."
  canonicalPath="/contact/"
  activeNav="contact"
  bodyClass="wp-singular page wp-theme-villazilla-85 contact sidebar-primary"
>
  <script slot="head" type="application/ld+json" set:html={breadcrumbLd} />
  <div slot="hero" set:html={hero} />
  <div class="page-header">
    <h1 class="title">Contact</h1>
    <div class="hr"></div>
    <h2 class="subtitle">Get in touch</h2>
  </div>
  <div class="row contact-static-box">
    <div class="col-md-8">
      <p class="contact-static-lead">
        For enquiries about Villa Vert Bocage, please email us or reach out via Facebook.
      </p>
      <ul class="contact-static-actions">
        <li>
          <strong>Email:</strong>
          <a href="mailto:stuart@blackrockservices.co.uk">stuart@blackrockservices.co.uk</a>
        </li>
        <li>
          <strong>Facebook:</strong>
          <a href="https://www.facebook.com/VillaVertBocage/">facebook.com/VillaVertBocage</a>
        </li>
      </ul>
      <p class="contact-static-note">
        This site is hosted as static pages; messages sent through the previous booking system are no longer available here.
        Use email or Facebook for the fastest response.
      </p>
    </div>
  </div>
</BaseLayout>
